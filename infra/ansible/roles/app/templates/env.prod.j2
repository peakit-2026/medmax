GITHUB_REPO={{ github_repo }}
ACME_EMAIL={{ acme_email }}

DB_USER={{ db_user | default('oculus') }}
DB_PASSWORD={{ db_password }}
DB_NAME={{ db_name | default('oculus') }}

JWT_SECRET={{ jwt_secret }}

AWS_ACCESS_KEY_ID={{ aws_access_key_id | default('') }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key | default('') }}
AWS_REGION={{ aws_region | default('ru-central1') }}
S3_BUCKET={{ s3_bucket | default('oculus-feldsher') }}
S3_ENDPOINT={{ s3_endpoint | default('https://s3.timeweb.cloud') }}

TELEGRAM_BOT_TOKEN={{ telegram_bot_token | default('') }}

BACKUP_S3_BUCKET={{ backup_s3_bucket | default('') }}
BACKUP_S3_ENDPOINT={{ backup_s3_endpoint | default('') }}
