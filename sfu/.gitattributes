# Force LF line endings for all files
* text=auto eol=lf

# Rust files
*.rs text eol=lf
*.toml text eol=lf
*.lock text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# YAML/YML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf
